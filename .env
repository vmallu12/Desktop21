# Timezone
TZ=UTC

# Desktop resolution
VNC_RESOLUTION=1366x768

# Desktop user
USER=desktop

# Display number
DISPLAY=:1

# noVNC port
NOVNC_PORT=6080

# VNC port
VNC_PORT=5901

# Color depth
VNC_DEPTH=24

# Firefox (disable sandbox if needed in some containers)
MOZ_DISABLE_CONTENT_SANDBOX=1

# Improve GUI responsiveness
LIBGL_ALWAYS_SOFTWARE=1
MESA_GL_VERSION_OVERRIDE=3.3

# Optional locale
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
